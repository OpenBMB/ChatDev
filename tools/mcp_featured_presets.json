      "title": "Fetch 抓取服务",
      "description": "适合网页抓取、页面正文提取和链接内容读取。",
      "mode": "mcp_remote",
      "prefix": "fetch",
      "server": "http://127.0.0.1:3001/mcp",
      "setup_hint": "适合研究、新闻整理、资料抓取类任务。通常可和 browser 预设一起使用。",
      "tooling_snippet": {
        "type": "mcp_remote",
        "prefix": "fetch",
        "config": {
          "server": "http://127.0.0.1:3001/mcp",
          "timeout": 30,
          "cache_ttl": 0
        }
      }
    },
